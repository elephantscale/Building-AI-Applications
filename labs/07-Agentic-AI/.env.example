# ============================================================
# 07-Agentic-AI — environment variables
# Copy this file to `.env` and fill in your keys.
# ============================================================

# --- Anthropic Claude (REQUIRED) ---
# Used by every lab for text, reasoning, vision and tool-calling.
ANTHROPIC_API_KEY=sk-ant-...

# --- Model selection (OPTIONAL) ---
# Defaults to claude-haiku-4-5 when unset. Set to any Claude model id to
# override every LLM call across all labs, e.g.:
#   LLM_MODEL=claude-opus-4-8
# LLM_MODEL=claude-haiku-4-5

# --- Tavily web search (REQUIRED for M4 and M5) ---
TAVILY_API_KEY=tvly-...
# Optional Tavily base URL override (used on the DeepLearning.AI platform).
# DLAI_TAVILY_BASE_URL=

# --- OpenAI (REQUIRED ONLY for the M5 image-generation step) ---
# Claude cannot generate images, so M5's Graphic Designer Agent uses OpenAI
# DALL·E 3 for the single image-generation call. Not needed for M2, M3, M4.
OPENAI_API_KEY=sk-...
