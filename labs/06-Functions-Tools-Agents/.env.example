# Anthropic API key — required for every lesson.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: override the default model (claude-haiku-4-5).
# e.g. LLM_MODEL=claude-opus-4-8
#
# NOTE ON TEMPERATURE: several notebooks pass temperature=0. That works on
# claude-haiku-4-5 (the default), but temperature is rejected (HTTP 400) on
# Opus 4.7+ and Sonnet 5. If you set LLM_MODEL to one of those, remove the
# temperature=0 arguments from the ChatAnthropic(...) calls.
LLM_MODEL=claude-haiku-4-5
