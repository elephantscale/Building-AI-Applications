# Anthropic API key — required for every notebook (the Claude LLM).
ANTHROPIC_API_KEY=sk-ant-...

# Generation model. Defaults to claude-haiku-4-5 if unset.
# Override to claude-opus-4-8 for higher quality, BUT see the temperature note
# in the README: L3 sets temperature=0, which Opus 4.7+ / Sonnet 5 reject with a
# 400. Remove the temperature argument before switching to those models.
LLM_MODEL=claude-haiku-4-5

# SQLite database file used by lessons 3, 4, and 5. It ships pre-built in the
# repo (test.db) and is also rebuilt from data/all-states-history.csv inside the
# notebooks, so this is optional / informational.
DATABASE_FILE_PATH=./test.db
