# --- Answer generation (Claude / Anthropic) ---
# Only the final answer-generation (RAG) step uses Claude.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional model override. Defaults to claude-haiku-4-5 when unset.
# Set to claude-opus-4-8 for the most capable option.
LLM_MODEL=claude-haiku-4-5

# --- Embeddings & Rerank (Cohere) — the teaching subject, kept as-is ---
COHERE_API_KEY=your-cohere-api-key
# Optional; used by the rerank lesson.
COHERE_RERANK_MODEL=rerank-english-v3.0

# --- Vector search backend (Weaviate) — kept as-is ---
WEAVIATE_API_URL=https://your-weaviate-cluster-url
WEAVIATE_API_KEY=your-weaviate-api-key
