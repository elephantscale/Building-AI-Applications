# Copy this file to `.env` and fill in your key.

# Anthropic API key for Claude (get one at https://console.anthropic.com/)
# This is the ONLY credential required to run the lab end-to-end.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model.
# The notebook defaults to claude-haiku-4-5 (fast + inexpensive for class use).
# For tougher tasks, try claude-opus-4-8.
# LLM_MODEL=claude-haiku-4-5

# ---------------------------------------------------------------------------
# OPTIONAL — Amazon Bedrock Guardrails (Step 3 only).
# AWS credentials are NOT required for this lab. Set these only if you want to
# exercise the managed Bedrock Guardrails path; otherwise Step 3 automatically
# falls back to the local guardrail from Step 2.
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_GUARDRAIL_ID=gr-xxxxxxxxxxxx
# BEDROCK_GUARDRAIL_VERSION=1
