# Anthropic API key — required for every notebook (the Claude LLM).
ANTHROPIC_API_KEY=sk-ant-...

# Generation model. Defaults to claude-haiku-4-5 if unset.
# Override to claude-opus-4-8 for higher quality (note: temperature must be
# removed/left at default on Opus 4.7+ / Sonnet 5 — see the temperature note in
# the README).
LLM_MODEL=claude-haiku-4-5

# Embeddings now run locally on-device (sentence-transformers/all-MiniLM-L6-v2)
# via langchain-huggingface. No OpenAI key is needed — only ANTHROPIC_API_KEY.
