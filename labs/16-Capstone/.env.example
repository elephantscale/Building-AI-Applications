# Copy this file to `.env` and fill in your key.

# Anthropic API key for Claude (get one at https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model.
# The capstone defaults to claude-haiku-4-5 (fast + inexpensive for the many
# small calls in this lab). For the tougher tier, try claude-opus-4-8.
# LLM_MODEL=claude-haiku-4-5
