# ─────────────────────────────────────────────────────────────────────────────
#  ONE .env for ALL labs.
#  Copy this file to `.env` in THIS directory and fill in your keys:
#      cp labs/.env.example labs/.env
#  Every lab picks it up automatically (each notebook's load_dotenv() walks up
#  from the lab folder to here). You only fill this in once.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — the model for every lab (get it at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model (labs default to claude-haiku-4-5).
# LLM_MODEL=claude-opus-4-8

# ── Per-lab keys (only needed if you run these specific labs) ────────────────

# Lab 03 (Semantic Search) — Cohere embeddings + rerank, and a Weaviate sandbox
# COHERE_API_KEY=
# COHERE_RERANK_MODEL=rerank-english-v3.0
# WEAVIATE_API_URL=
# WEAVIATE_API_KEY=

# Lab 07 (Agentic AI) — Tavily web research (free tier), and OpenAI ONLY for the
# optional DALL·E image-generation step (Claude has no image generation)
# TAVILY_API_KEY=
# OPENAI_API_KEY=

# Lab 08 (Database Agent) — optional custom SQLite path (defaults work without it)
# DATABASE_FILE_PATH=

# Labs 09/10 (Bedrock) use standard AWS credentials — configure with `aws configure`
# or the usual AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_DEFAULT_REGION env vars,
# not this file.
