# --- Anthropic (Claude) — used for text generation in RetrievalQA /
#     ConversationalRetrievalChain (Lessons 5 & 6) ---
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model. Defaults to claude-haiku-4-5.
# Set to claude-opus-4-8 for the strongest model.
# LLM_MODEL=claude-haiku-4-5

# --- OpenAI — used ONLY for embeddings (text-embedding-3-small) that build
#     the Chroma / DocArray vector store. This lab needs BOTH keys. ---
OPENAI_API_KEY=sk-...

# --- Optional: LangSmith tracing (referenced in Lessons 5 & 6) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=ls-...
